model DashboardNotificationSetting {
  id                   String   @id @default(cuid())
  orderUpdates         Boolean  @default(true)
  lowStockAlerts       Boolean  @default(true)
  newUserRegistrations Boolean  @default(true)
  revenueReports       Boolean  @default(true)
  promotionsOffers     Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model CustomerNotificationSetting {
  id                        String   @id @default(cuid())
  userId                    String   @unique
  user                      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  newProductsArrive         Boolean  @default(true)
  latestOffersAdd           Boolean  @default(true)
  orderPurchasedSuccessfully Boolean  @default(true)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}
