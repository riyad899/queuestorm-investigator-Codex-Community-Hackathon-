model HomeBannerSetting {
  id                 String   @id @default(cuid())
  homeBanners        String[]
  recommendedBanners String[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model HomeAdSetting {
  id            String   @id @default(cuid())
  bigAdImage    String?
  sideAdImages   String[] @default([])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model HomeLogoSliderItem {
  id        String   @id @default(cuid())
  name      String
  logoUrl   String
  linkUrl   String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteTheme {
  id                 String   @id @default(cuid())
  name               String   @unique
  colorPrimaryBg     String
  colorSecondaryCard String
  colorButton        String
  colorIcon          String
  colorIconMuted     String
  colorBar           String
  colorFont          String
  colorBorderShade   String
  isActive           Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model PopularCategory {
  id         String   @id @default(cuid())
  categoryId String   @unique
  sortOrder  Int      @default(0)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model RecommendedCategory {
  id         String   @id @default(cuid())
  categoryId String   @unique
  sortOrder  Int      @default(0)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Testimonial {
  id          String   @id @default(cuid())
  description String
  userImage   String
  userName    String
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
