model LatestOffer {
  id           String   @id @default(cuid())
  title        String
  description  String?
  offerStartAt DateTime
  offerEndAt   DateTime
  isActive     Boolean  @default(true)

  products LatestOfferProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LatestOfferProduct {
  id            String @id @default(cuid())
  latestOfferId String
  productId     String

  latestOffer LatestOffer @relation(fields: [latestOfferId], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([latestOfferId, productId])
}
